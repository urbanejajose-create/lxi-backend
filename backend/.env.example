# Environment Configuration - LXI E-commerce API

# MongoDB Configuration
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=lxi_ecommerce

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-at-least-32-chars
ALGORITHM=HS256

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CORS Configuration
CORS_ORIGINS=https://wearelxi.com,https://www.wearelxi.com,http://localhost:3000,http://localhost:5173

# Email Configuration (Optional - for future email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=urbanejajose@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=urbanejajose@gmail.com

# API Configuration
API_TITLE=LXI E-commerce API
API_VERSION=2.0.0
DEBUG=False

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox

# Printful Configuration
PRINTFUL_API_KEY=your_printful_api_key
PRINTFUL_STORE_ID=your_store_id
PRINTFUL_WEBHOOK_SECRET_HEX=your_printful_webhook_secret_hex

# Production URL Convention
# Frontend: https://wearelxi.com
# Backend: https://api.wearelxi.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
