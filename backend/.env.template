# ====================================================================
# LXI E-COMMERCE BACKEND - TEMPLATE DE CONFIGURACIÓN
# ====================================================================
# INSTRUCCIONES:
# 1. Completa cada valor con tus credenciales reales
# 2. Guarda como ".env" (sin .template)
# 3. Nunca compartas este archivo en GitHub

# ====================================================================
# 🗄️ DATABASE - MongoDB
# ====================================================================

# OPCION 1: Local (testing)
MONGO_URL=mongodb://localhost:27017
DB_NAME=lxi_db

# OPCION 2: MongoDB Atlas
# MONGO_URL=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# DB_NAME=lxi_db

# ====================================================================
# 💳 STRIPE - Pasarela de Pago
# ====================================================================

# TEST MODE (para desarrollo local)
# Obtén en: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_REEMPLAZA_CON_TU_KEY_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA_CON_TU_WEBHOOK_SECRET

# PRODUCTION (cuando vayas a live)
# STRIPE_API_KEY=sk_live_REEMPLAZA_CON_TU_KEY_PRODUCTION

# ====================================================================
# 🖨️ PRINTFUL - Print-on-Demand
# ====================================================================

# TEST MODE (para desarrollo)
# Obtén en: https://app.printful.com/ → Settings → API
PRINTFUL_API_KEY=pfapikey_REEMPLAZA_CON_TU_KEY_PRINTFUL
PRINTFUL_WEBHOOK_SECRET_HEX=REEMPLAZA_CON_EL_SECRET_HEX_DEL_WEBHOOK

# Ambiente
PRINTFUL_ENV=test
# PRINTFUL_ENV=live (cuando vayas a producción)

# ====================================================================
# 🔐 SEGURIDAD - JWT & Secretos
# ====================================================================

# Cambiar esta key antes de ir a producción!
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=lxi-secret-key-12345-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====================================================================
# PAYPAL
# ====================================================================

PAYPAL_CLIENT_ID=REEMPLAZA_CON_TU_CLIENT_ID
PAYPAL_CLIENT_SECRET=REEMPLAZA_CON_TU_CLIENT_SECRET
PAYPAL_ENV=sandbox

# ====================================================================
# 🌐 CORS & HOSTING
# ====================================================================

CORS_ORIGINS="*"

# Cuando actives tu dominio, actualiza a:
# CORS_ORIGINS="https://wearelxi.com,https://www.wearelxi.com,http://localhost:3000"

# ====================================================================
# 🚀 AMBIENTE
# ====================================================================

ENVIRONMENT=development
# ENVIRONMENT=production (en Namecheap)

DEBUG=True
# DEBUG=False (en producción)

LOG_LEVEL=INFO

# ====================================================================
# 📧 EMAIL (Opcional - para futuro)
# ====================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=urbanejajose@gmail.com
# SMTP_PASSWORD=tu_app_password
# SMTP_FROM=urbanejajose@gmail.com

# ====================================================================
# 🌍 WEBHOOKS
# ====================================================================

# Cuando uses Stripe CLI o webhooks externos, la URL publica sera distinta.
# Ejemplo backend publico: https://api.wearelxi.com

# ====================================================================
# 📊 VERSION & BRANDING
# ====================================================================

API_VERSION=2.0.0
BRAND=LXI
EDITION=Founders MMXXVI
